---
import GitIcon from "../assets/icons/Github.svg"
import { Sun } from "lucide-react"
import { Moon } from "lucide-react"
import { Button } from "@/components/ui/button"
---

<!-- Your Navbar (Unchanged) -->
<nav
  class="flex items-center justify-between w-full px-6 py-4 border-b border-border bg-background text-foreground font-serif text-2xl"
>
  <div class="flex items-center gap-4 flex-1 justify-start text-sm font-medium">
    <a href="https://github.com/las-vejas" class="hover:text-muted-foreground"><GitIcon class:list={"h-5 w-5"} /></a>
    <a href="/contact" class="hover:text-muted-foreground text-2xl">Contact</a>
    <a href="/blog" class="hover:text-muted-foreground text-2xl">Blog</a>
    <a href="/guestbook" class="hover:text-muted-foreground text-2xl">Guestbook</a>
    <a href="/projects" class="hover:text-muted-foreground hover:underline text-2xl">Projects</a>
  </div>
  <div class="flex flex-1 justify-center">
    <a href="/" class="text-5xl font-serif">Vejas</a>
  </div>
  <div class="flex flex-1 justify-end">
    <Button id="themeToggle" variant={"outline"} size={"icon-lg"}>
      <Sun className="hidden dark:block" />
      <Moon className="block dark:hidden" />
    </Button>
  </div>
</nav>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement
    element.classList.toggle("dark")
    const isDark = element.classList.contains("dark")
    localStorage.setItem("theme", isDark ? "dark" : "light")
  }
  document
    .getElementById("themeToggle")
    ?.addEventListener("click", handleToggleClick)
</script>
