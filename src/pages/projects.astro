---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"
import { Image } from "astro:assets"
import { ArrowUpRight, Code2, Layers } from "lucide-react"
import { userData } from "@/lib/user-data"
import { getCollection, render } from "astro:content"
import { Badge } from "@/components/ui/badge"


const projects = await getCollection("projects")
const rendered = await Promise.all(
  projects.map(async (p: any) => ({ ...p, content: await render(p) }))
)
---

<Layout>
  <!-- Header -->
  <div
    class="flex flex-col items-center justify-center px-4 pt-20 pb-14 text-center sm:px-6 sm:pt-24 sm:pb-16"
  >
    <h1 class="mb-4 text-4xl font-serif sm:text-5xl md:text-6xl">Projects</h1>
    <p class="text-muted-foreground text-sm">Some of my best work.</p>
  </div>

  <!-- Grid -->
  <div
    class="grid w-full grid-cols-1 gap-4 rounded-2xl border-border/40 p-0 md:grid-cols-2"
  >
    {
      rendered.map(({ slug, data, content: { Content } }, i) => (
        <div
          class="project-card group relative flex flex-col rounded-2xl border border-border/40 p-6 cursor-pointer hover:bg-accent/20 sm:p-8"
          data-title={data.title}
          data-category={data.category ?? ""}
          data-github={data.github ?? ""}
          data-imgsrc={data.image?.src ?? ""}
          data-tags={data.tags?.join(",") ?? ""}
        >
          <div class="flex items-start gap-6">
            {data.image && (
              typeof data.image === "string" && data.image.startsWith("http") ? (
                <img
                  src={data.image}
                  alt={data.title}
                  class="w-2/5 rounded-xl object-cover shrink-0 aspect-video"
                />
              ) : (
                <Image
                  src={data.image}
                  alt={data.title}
                  class="w-2/5 rounded-xl object-cover shrink-0 aspect-video"
                  inferSize={true}
                />
              )
            )}
            <div class="flex flex-col gap-3 flex-1">
              <h2 class="text-2xl font-serif leading-tight sm:text-3xl">{data.title}</h2>
              <div class="flex flex-wrap gap-2">
                {data.tags?.map((tag: string) => (
                  <Badge variant="secondary">{tag}</Badge>
                ))}
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">
                {data.description}
              </p>
              <div class="flex gap-2 mt-2">
                <span class="inline-flex min-h-11 items-center justify-center gap-1 rounded-[min(var(--radius-md),12px)] border border-transparent bg-primary px-3.5 text-sm font-medium whitespace-nowrap text-primary-foreground">
                  <ArrowUpRight /> Read more
                </span>
                {data.github && (
                  <Button
                    asChild
                    variant="outline"
                    size="sm"
                    className="h-11 px-4"
                  >
                    <a
                      href={data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      onclick="event.stopPropagation()"
                    >
                      <Code2 /> Repository
                    </a>
                  </Button>
                )}
              </div>
            </div>
          </div>

          <div class="hidden" data-content>
            <div class="prose dark:prose-invert prose-sm max-w-none">
              <Content />
            </div>
          </div>
          <div class="hidden" data-modal-actions>
            {data.github && (
              <Button asChild variant="outline" size="sm" className="h-11 px-4">
                <a href={data.github} target="_blank" rel="noopener noreferrer">
                  <Code2 /> Repository
                </a>
              </Button>
            )}
            {data.links?.map(
  (link: { label: string; url: string; icon?: string; color?: string; variant?: "default" | "outline" | "secondary" | "ghost" | "destructive" | "link" | "blueprint" }) => (
    <Button asChild variant={link.variant ?? "outline"} size="sm" className="h-11 px-4">
      <a href={link.url} target="_blank" rel="noopener noreferrer">
        {link.icon === "globe" && <ArrowUpRight />}
        {link.icon === "link" && <ArrowUpRight />}
        {link.icon === "youtube" && <ArrowUpRight />}
        {link.icon === "download" && <ArrowUpRight />}
        {link.icon === "bp" && <Layers />}
        {link.label}
      </a>
    </Button>
  )
)}
          </div>
        </div>
      ))
    }
  </div>

  <!-- Modal -->
  <div
    id="project-modal"
    class="fixed inset-0 z-50 hidden items-start justify-center pt-16 px-4 pb-8">

    <div
      id="modal-backdrop"
      class="absolute inset-0 bg-background/80 backdrop-blur-sm"
    >
    </div>

    <!-- Panel -->
    <div
      class="relative z-10 flex max-h-[80vh] w-full max-w-2xl flex-col overflow-hidden rounded-2xl border border-border bg-card"
    >
      <button
        id="modal-close"
        class="absolute top-4 left-4 p-2 rounded-md hover:bg-accent"
        aria-label="Close"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Modal header -->
      <div
        class="flex shrink-0 items-start justify-between border-b border-border/40 px-6 pb-6 pt-12 sm:px-8 sm:pb-8 sm:pt-14"
      >
        <div class="flex flex-col gap-2">
          <h2 id="modal-title" class="text-3xl font-serif sm:text-4xl"></h2>
          <div id="modal-tags"></div>
          <div id="modal-github"></div>
        </div>
        <div id="modal-image" class="w-1/3 shrink-0 ml-6"></div>
      </div>

      <!-- Modal body -->
      <div
        id="modal-body"
        class="overflow-y-auto p-6 text-sm leading-relaxed text-muted-foreground sm:p-8"
      >
      </div>
    </div>
  </div>
</Layout>

<script>
  const cards = document.querySelectorAll<HTMLElement>(".project-card")
  const modal = document.getElementById("project-modal")!
  const backdrop = document.getElementById("modal-backdrop")!
  const modalTitle = document.getElementById("modal-title")!
  const modalBody = document.getElementById("modal-body")!
  const modalImage = document.getElementById("modal-image")!
  const modalGithub = document.getElementById("modal-github")!
  const modalTags = document.getElementById("modal-tags")!
  const closeBtn = document.getElementById("modal-close")!

  const openModal = (card: HTMLElement) => {
    const title = card.dataset.title ?? ""
    const github = card.dataset.github ?? ""
    const imgSrc = card.dataset.imgsrc ?? ""
    const tags = card.dataset.tags ? card.dataset.tags.split(",") : []
    const content = card.querySelector("[data-content]") as HTMLElement

    modalTitle.textContent = title
    modalBody.innerHTML = content.innerHTML

    modalImage.innerHTML = imgSrc
      ? `<img src="${imgSrc}" alt="${title}" class="rounded-xl object-cover w-full aspect-video" />`
      : ""

    const actions = card.querySelector("[data-modal-actions]") as HTMLElement
    modalGithub.innerHTML = actions.innerHTML

    modalTags.innerHTML = tags.length
      ? `<div class="flex flex-wrap gap-2">${tags
          .map(
            (t) =>
              `<span class="text-xs font-sans border border-border rounded-md px-2 py-1 text-muted-foreground">${t}</span>`
          )
          .join("")}</div>`
      : ""

    modal.classList.remove("hidden")
    modal.classList.add("flex")
    document.body.style.overflow = "hidden"
  }

  const closeModal = () => {
    modal.classList.add("hidden")
    modal.classList.remove("flex")
    document.body.style.overflow = ""
  }

  cards.forEach((card) => {
    card.addEventListener("click", () => openModal(card))
  })

  closeBtn.addEventListener("click", closeModal)
  backdrop.addEventListener("click", closeModal)

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal()
  })
</script>
