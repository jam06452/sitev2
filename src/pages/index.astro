---
import Layout from "@/layouts/main.astro"
import { Button } from "@/components/ui/button"
import { ArrowUpRight } from "lucide-react"
import { userData } from "@/lib/user-data"
import { getCollection, render } from "astro:content"
const projects = await getCollection("projects")
const rendered = await Promise.all(
  projects.map(async (p: any) => ({ ...p, content: await render(p) }))
)
const featured = rendered
  .filter((p: any) => p.data.featured)
  .sort((a: any, b: any) => Number(Boolean(b.data.image)) - Number(Boolean(a.data.image)))
  .slice(0, 2)
---


<Layout>
  <!-- HERO -->
  <div
    class="flex flex-col w-full p-6 pt-32 pb-48 items-center justify-start text-center gap-6"
  >
    <img
      src={userData.cdn.assets.heroDark}
      alt="Hero illustration"
      aria-label={userData.fullName}
      class="w-full max-w-4xl hidden dark:block"
    />
    <img
      src={userData.cdn.assets.heroLight}
      alt="Hero illustration"
      aria-label={userData.fullName}
      class="w-full max-w-4xl dark:hidden"
    />

    <h2 class="text-3xl font-serif max-w-xl balance">
      is a {userData.bio.split("based")[1].trim()}
    </h2>
  </div>

  <!-- MAIN GRID -->
  <div class="grid grid-cols-1 lg:grid-cols-2 w-full border-t border-border/40 items-start mb-32">

    <!-- PROJECTS -->
    <div class="flex items-center flex-col justify-center p-12 border-r border-border/40">
      <h1 class="text-7xl font-serif pb-12">Projects</h1>

      <div class="pb-6">
        {
          featured.map((p: any, i: number) => (
            <div class={i % 2 === 1 ? "flex flex-row-reverse items-start gap-4 pb-10" : "flex items-start gap-4 pb-10"}>
              {
                p.data.image ? (
                  typeof p.data.image === "string" && p.data.image.startsWith("http") ? (
                    <img src={p.data.image} alt={p.data.title} class="w-2/5 h-auto rounded-2xl object-cover shrink-0" />
                  ) : (
                    <img src={p.data.image.src} alt={p.data.title} class="w-2/5 h-auto rounded-2xl object-cover shrink-0" />
                  )
                ) : null
              }

              <div class="flex flex-col gap-2">
                <h2 class="text-3xl font-serif">{p.data.title}</h2>

                <p class="text-sm text-muted-foreground">{p.data.description}</p>

                <div class="flex gap-2">
                  <a href={`/projects/${p.id}`}>
                    <Button variant="default" size="sm">
                      <ArrowUpRight /> Read more
                    </Button>
                  </a>

                  {p.data.github && (
                    <a href={p.data.github} target="_blank">
                      <Button variant="outline" size="sm">
                        <img src={userData.cdn.assets.githubIcon} alt="" class="size-4" />
                        Repository
                      </Button>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <a href="/projects">
        <Button variant="outline" size="lg">
          <ArrowUpRight /> Projects Page
        </Button>
      </a>
    </div>

    <!-- BLOG -->
    <div class="flex items-center flex-col justify-center p-12">
      <h1 class="text-7xl font-serif pb-12">Blog</h1>
      <p class="text-xs text-muted-foreground text-center pt-2">
        Posts coming soon!
      </p>
    </div>

  </div>
</Layout>