---
import Layout from "@/layouts/main.astro"
import { getCollection, getEntry, render } from "astro:content"
import { Image } from "astro:assets"
import { Button } from "@/components/ui/button"
import { ArrowUpRight } from "lucide-react"
import { userData } from "@/lib/user-data"

export async function getStaticPaths() {
  const projects = await getCollection("projects")
  return projects.map((project: any) => {
    if (!project.id) {
      throw new Error("Project entry missing id")
    }

    return { params: { slug: project.id } }
  })
}

const { slug } = Astro.params
const project = await getEntry("projects", slug)
if (!project) {
  throw new Error(`Project not found: ${slug}`)
}

const projectImage = project.data.image as string | { src: string } | undefined
const localProjectImage = typeof projectImage === "string" ? undefined : projectImage

const { Content } = await render(project)
---

<Layout>
  <div class="max-w-3xl mx-auto pt-32 pb-24 px-6">
    <h1 class="text-6xl font-serif mb-4">{project.data.title}</h1>
    {projectImage && (
      typeof projectImage === "string" && projectImage.startsWith("http") ? (
        <img src={projectImage} alt={project.data.title} class="w-full rounded-xl object-cover mb-6 aspect-video" />
      ) : (
        localProjectImage && (
          <Image src={localProjectImage} alt={project.data.title} class="w-full rounded-xl object-cover mb-6 aspect-video" inferSize={true} />
        )
      )
    )}

    <p class="text-muted-foreground mb-6">{project.data.description}</p>

    <div class="prose dark:prose-invert">
      <Content />
    </div>

    <div class="mt-6 flex gap-2">
      {project.data.github && (
        <a href={project.data.github} target="_blank">
          <Button variant="outline"><ArrowUpRight /> Repository</Button>
        </a>
      )}
      <a href="/projects">
        <Button variant="ghost">Back</Button>
      </a>
    </div>
  </div>
</Layout>
